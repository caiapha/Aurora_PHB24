			<stat name="experimental elixir:speed_increase" value="5" level="9"/>
			<stat name="experimental elixir:speed_increase" value="5" level="15"/>
		</rules>
	</element>
	<element name="3 - Resilience Elixir" type="Archetype Feature" source="Eberron: Forge of the Artificer" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_EXPERIMENTAL_ELIXIR_RESILIENCE">
		<sheet>
			<description level="3">The drinker gains +1AC for 10 minutes.</description>
			<description level="9">The drinker gains +1AC for 1 hour.</description>
			<description level="15">The drinker gains +1AC for 8 hours.</description>
