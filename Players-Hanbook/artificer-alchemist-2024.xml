	<element name="4 - Boldness Elixir" type="Archetype Feature" source="Eberron: Forge of the Artificer" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_EXPERIMENTAL_ELIXIR_BOLDNESS">
		<sheet>
			<description level="3">The drinker rolls 1d4. For 1 minute, he adds the result to every attack roll and saving throw.</description>
			<description level="9">The drinker rolls 1d4. For 10 minutes, he adds the result to every attack roll and saving throw.</description>
			<description level="15">The drinker rolls 1d4. For 1 hour, he adds the result to every attack roll and saving throw.</description>
		</sheet>
	</element>
		<element name="5 - Elixir of Flight" type="Archetype Feature" source="Eberron: Forge of the Artificer" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_EXPERIMENTAL_ELIXIR_FLIGHT">
