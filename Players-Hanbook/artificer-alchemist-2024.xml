	<element name="Alchemist" type="Archetype" source="Eberron: Forge of the Artificer" id="ID_WOTC_EFA_ARCHETYPE_ARTIFICER_ALCHEMIST">
		<supports>Artificer Subclass, EFA Version</supports>
		<description>
			<p>An Alchemist is an expert at combining reagents to produce mystical effects. Alchemists use their creations to give life and to leech it away. Alchemy is the oldest of artificer traditions, and its versatility has long been valued during times of war and peace.</p>
			<div element="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_TOOLS_OF_THE_TRADE" />
			<div element="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_ALCHEMIST_SPELLS" />
			<div element="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_EXPERIMENTAL_ELIXIR" />
			<div element="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_ALCHEMICAL_SAVANT" />
			<div element="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_RESTORATIVE_REAGENTS" />
			<div element="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_CHEMICAL_MASTERY" />
		</description>
		<sheet display="false" />
		<rules>
			<grant type="Archetype Feature" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_TOOLS_OF_THE_TRADE" level="3" />
			<grant type="Archetype Feature" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_ALCHEMIST_SPELLS" level="3" />
			<grant type="Archetype Feature" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_EXPERIMENTAL_ELIXIR" level="3" />
			<grant type="Archetype Feature" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_ALCHEMICAL_SAVANT" level="5" />
			<grant type="Archetype Feature" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_RESTORATIVE_REAGENTS" level="9" />
			<grant type="Archetype Feature" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_CHEMICAL_MASTERY" level="15" />
		</rules>
	</element>
	<element name="Tools of the Trade" type="Archetype Feature" source="Eberron: Forge of the Artificer" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_TOOLS_OF_THE_TRADE">
		<description>
			<p><strong>Tool proficiency</strong>You gain proficiency with Alchemist's Supplies and the Herbalism Kit. If you already have one of these proficiencies, you gain proficiency with one other type of Artisan's Tools of your choice (or with two other types if you have both).</p>
			<p><strong>Potion Crafting.</strong> When you brew a potion using the crafting rules in the Dungeon Master's Guide, the amount of time required to craft it is halved.</p>
		</description>
		<sheet>
			<description>The crafing time to brew potions is halved.</description>
		</sheet>	
		<rules>
			<grant type="Proficiency" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_TOOLS_OF_THE_TRADE_1" requirements="!ID_PROFICIENCY_TOOL_PROFICIENCY_ALCHEMISTS_SUPPLIES, !ID_PROFICIENCY_TOOL_PROFICIENCY_HERBALISM_KIT" />
			<grant type="Proficiency" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_TOOLS_OF_THE_TRADE_2" requirements="ID_PROFICIENCY_TOOL_PROFICIENCY_ALCHEMISTS_SUPPLIES, !ID_PROFICIENCY_TOOL_PROFICIENCY_HERBALISM_KIT"/>
			<grant type="Proficiency" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_TOOLS_OF_THE_TRADE_3" requirements="!ID_PROFICIENCY_TOOL_PROFICIENCY_ALCHEMISTS_SUPPLIES, ID_PROFICIENCY_TOOL_PROFICIENCY_HERBALISM_KIT"/>
			<grant type="Proficiency" id="ID_WOTC_EFA_ARCHETYPE_FEATURE_ALCHEMIST_TOOLS_OF_THE_TRADE_4" requirements="ID_PROFICIENCY_TOOL_PROFICIENCY_ALCHEMISTS_SUPPLIES, ID_PROFICIENCY_TOOL_PROFICIENCY_HERBALISM_KIT"/>
		</rules>
	</element>
